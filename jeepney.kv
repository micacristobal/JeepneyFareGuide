#:set peach_light (1, 0.92, 0.88, 1)
#:set peach (1, 0.84, 0.74, 1)
#:set peach_dark (0.96, 0.72, 0.6, 1)
#:set peach_selected (0.9, 0.58, 0.42, 1)
#:set peach_border (0.9, 0.6, 0.5, 1)
#:import dp kivy.metrics.dp
#:set tile_size "92dp"

RootManager:
    StartScreen:
    FareScreen:

<StartScreen>:
    name: "start"
    BoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "16dp"
        canvas.before:
            Color:
                rgba: peach_light
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: peach
            Rectangle:
                pos: self.pos[0], self.pos[1] + self.height * 0.45
                size: self.size[0], self.height * 0.55
        Label:
            text: "JEEPNEY FARE GUIDE"
            font_size: "26sp"
            color: 0, 0, 0, 1
            size_hint_y: 0.4
        Button:
            text: "START"
            size_hint: 1, None
            height: "48dp"
            background_color: 0, 0, 0, 0
            color: 0, 0, 0, 1
            font_size: "16sp"
            on_release: app.root.current = "fare"
            on_press: app.animate_press(self)
            canvas.before:
                Color:
                    rgba: peach
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
            canvas.after:
                Color:
                    rgba: peach_border
                Line:
                    width: 1
                    rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25

<PlaceButton>:
    size_hint: 1, 1
    background_color: 0, 0, 0, 0
    color: 0, 0, 0, 1
    font_size: "10sp"
    text_size: self.width - dp(6), self.height - dp(6)
    halign: "center"
    valign: "middle"
    on_press: app.animate_press(self)
    canvas.before:
        Color:
            rgba: peach_selected if self.state == "down" else peach
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
    canvas.after:
        Color:
            rgba: peach_border
        Line:
            width: 1
            rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25

<FareTypeButton@ToggleButton>:
    background_color: 0, 0, 0, 0
    color: 0, 0, 0, 1
    font_size: "12sp"
    on_press: app.animate_press(self)
    canvas.before:
        Color:
            rgba: peach_selected if self.state == "down" else peach
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
    canvas.after:
        Color:
            rgba: peach_border
        Line:
            width: 1
            rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25

<FareScreen>:
    name: "fare"
    BoxLayout:
        orientation: "vertical"
        padding: "16dp"
        spacing: "8dp"
        canvas.before:
            Color:
                rgba: peach_light
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: peach
            Rectangle:
                pos: self.pos
                size: self.size[0], self.height * 0.25
        BoxLayout:
            size_hint_y: None
            height: "40dp"
            spacing: "6dp"
            Button:
                text: "BACK"
                size_hint_x: None
                width: "64dp"
                background_color: 0, 0, 0, 0
                color: 0, 0, 0, 1
                font_size: "12sp"
                on_release: app.root.current = "start"
                on_press: app.animate_press(self)
                canvas.before:
                    Color:
                        rgba: peach
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
                canvas.after:
                    Color:
                        rgba: peach_border
                    Line:
                        width: 1
                        rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25
            Label:
                text: "FARE CALCULATOR"
                color: 0, 0, 0, 1
                font_size: "18sp"
        BoxLayout:
            size_hint_y: None
            height: "34dp"
            spacing: "6dp"
            padding: "4dp", "0dp"
            ToggleButton:
                text: "SM SAN MATEO → SAN JOSE"
                group: "route"
                state: "down"
                on_release: root.set_route("sm_to_sj")
                background_color: 0, 0, 0, 0
                color: 0, 0, 0, 1
                font_size: "11sp"
                text_size: self.width - dp(12), self.height - dp(6)
                halign: "center"
                valign: "middle"
                on_press: app.animate_press(self)
                canvas.before:
                    Color:
                        rgba: peach
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
                canvas.after:
                    Color:
                        rgba: peach_border
                    Line:
                        width: 1
                        rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25
            ToggleButton:
                text: "SAN JOSE → SM SAN MATEO"
                group: "route"
                on_release: root.set_route("sj_to_sm")
                background_color: 0, 0, 0, 0
                color: 0, 0, 0, 1
                font_size: "11sp"
                text_size: self.width - dp(12), self.height - dp(6)
                halign: "center"
                valign: "middle"
                on_press: app.animate_press(self)
                canvas.before:
                    Color:
                        rgba: peach
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
                canvas.after:
                    Color:
                        rgba: peach_border
                    Line:
                        width: 1
                        rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25
        BoxLayout:
            size_hint_y: None
            height: "40dp"
            spacing: "6dp"
            FareTypeButton:
                id: fare_regular
                text: "REGULAR"
                group: "fare_type"
                state: "down"
                on_release: root.set_fare_type("regular")
            FareTypeButton:
                id: fare_student
                text: "STUDENT"
                group: "fare_type"
                on_release: root.set_fare_type("student")
            FareTypeButton:
                id: fare_senior
                text: "SENIOR"
                group: "fare_type"
                on_release: root.set_fare_type("senior")
            FareTypeButton:
                id: fare_pwd
                text: "PWD"
                group: "fare_type"
                on_release: root.set_fare_type("pwd")
        ScrollView:
            do_scroll_x: False
            size_hint_y: 1
            AnchorLayout:
                anchor_x: "center"
                anchor_y: "top"
                size_hint_y: None
                height: places_grid.minimum_height
                GridLayout:
                    id: places_grid
                    cols: min(4, max(4, int(self.width / dp(56))))
                    size_hint_x: 1
                    size_hint_y: None
                    spacing: "8dp"
                    padding: "16dp", "8dp"
                    row_force_default: True
                    col_force_default: True
                    col_default_width: min(dp(72), max(dp(52), (self.width - dp(32) - (self.cols - 1) * dp(8)) / self.cols))
                    row_default_height: self.col_default_width
                    width: self.parent.width
                    height: self.minimum_height
        BoxLayout:
            size_hint_y: None
            height: "40dp"
            spacing: "8dp"
            Label:
                text: "ADD COMMUTER"
                size_hint_x: None
                width: "120dp"
                color: 0, 0, 0, 1
                font_size: "12sp"
            Button:
                text: "+"
                size_hint_x: None
                width: "48dp"
                on_release: root.add_commuter_fare()
                background_color: 0, 0, 0, 0
                color: 0, 0, 0, 1
                font_size: "18sp"
                on_press: app.animate_press(self)
                canvas.before:
                    Color:
                        rgba: peach
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
                canvas.after:
                    Color:
                        rgba: peach_border
                    Line:
                        width: 1
                        rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25
            Button:
                text: "="
                size_hint_x: None
                width: "48dp"
                on_release: root.calculate_total()
                background_color: 0, 0, 0, 0
                color: 0, 0, 0, 1
                font_size: "18sp"
                on_press: app.animate_press(self)
                canvas.before:
                    Color:
                        rgba: peach
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
                canvas.after:
                    Color:
                        rgba: peach_border
                    Line:
                        width: 1
                        rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25
        BoxLayout:
            size_hint_y: None
            height: "72dp"
            orientation: "vertical"
            spacing: "4dp"
            Label:
                id: fare_label
                text: "Select two places"
                color: 0, 0, 0, 1
                font_size: "20sp"
            Label:
                id: total_label
                text: ""
                color: 0, 0, 0, 1
                font_size: "20sp"
        Button:
            text: "RESET"
            size_hint_y: None
            height: "44dp"
            on_release: root.reset_all()
            background_color: 0, 0, 0, 0
            color: 0, 0, 0, 1
            font_size: "14sp"
            on_press: app.animate_press(self)
            canvas.before:
                Color:
                    rgba: peach
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [self.height * 0.25, self.height * 0.25, self.height * 0.25, self.height * 0.25]
            canvas.after:
                Color:
                    rgba: peach_border
                Line:
                    width: 1
                    rounded_rectangle: self.x, self.y, self.width, self.height, self.height * 0.25
